generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model CalorieHistory {
  id        String   @id @default(cuid())
  weight    Float
  height    Float
  age       Int
  gender    String
  activity  String
  tdee      Int
  lean      Int
  normal    Int
  createdAt DateTime @default(now())
}